{
  "name": "jh-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:e2e-seed": "tsx prisma/e2e-seed.ts",
    "db:studio": "prisma studio",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/db-backup.ps1",
    "db:restore": "powershell -ExecutionPolicy Bypass -File scripts/db-restore.ps1",
    "test:e2e": "pnpm prisma:e2e-seed && playwright test",
    "test:e2e:ui": "pnpm prisma:e2e-seed && playwright test --ui"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "framer-motion": "12.23.25",
    "lucide-react": "0.468.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "9.0.1",
    "rehype-highlight": "7.0.1",
    "rehype-sanitize": "6.0.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "prisma": "5.22.0",
    "tsx": "^4.22.4",
    "typescript": "5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
